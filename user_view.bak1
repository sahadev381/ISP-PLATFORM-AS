<?php
include 'config.php';
include 'includes/auth.php';
include 'includes/genieacs_api.php';

/* ============================
   DELETE USER
============================ */
if (isset($_GET['del'])) {
    $username = $conn->real_escape_string($_GET['del']);

    if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['disconnect'])) {
        $nas = $conn->query("SELECT * FROM nas WHERE status=1 LIMIT 1")->fetch_assoc();
        if ($nas) {
            $cmd = "echo 'User-Name = {$username}' | /usr/bin/radclient -x {$nas['ip_address']}:3799 disconnect {$nas['secret']} 2>&1";
            exec($cmd);
        }
    }

    $conn->begin_transaction();
    try {
        $conn->query("DELETE FROM radacct WHERE username='$username'");
        $conn->query("DELETE FROM radreply WHERE username='$username'");
        $conn->query("DELETE FROM radcheck WHERE username='$username'");
        $conn->query("DELETE FROM radusergroup WHERE username='$username'");
        $conn->query("DELETE FROM customers WHERE username='$username'");
        $conn->commit();
        header("Location: users.php?msg=deleted");
        exit;
    } catch (Exception $e) {
        $conn->rollback();
        die("Delete failed");
    }
}

/* ============================
   LOAD USER
============================ */
$username = $_GET['user'] ?? '';
$user = $conn->query("SELECT * FROM customers WHERE username='$username'")->fetch_assoc();
if (!$user) die("User not found");

/* ============================
   CURRENT SESSION
============================ */
$current_session = $conn->query("
    SELECT *, TIMESTAMPDIFF(SECOND, acctstarttime, NOW()) AS session_seconds
    FROM radacct
    WHERE username='$username' AND acctstoptime IS NULL
    ORDER BY acctstarttime DESC LIMIT 1
");

/* ============================
   GENIE ACS AUTO LINK (EXPANDED SCAN)
============================ */
 $device = null;
 $genieacsDevice = null;

 $target_serial = strtoupper(trim($user['onu_serial'] ?? ''));

if (!empty($target_serial)) {
    
    $devices = genieacs_request("/devices?_limit=1000&_sort=-_lastInform", "GET", null);

    if (is_array($devices)) {
        foreach ($devices as $d) {
            $found_serial = strtoupper(trim($d['_deviceId']['_SerialNumber'] ?? ''));

            if ($found_serial === $target_serial) {
                
                if (empty($user['tr069_device_id'])) {
                    $stmt = $conn->prepare("UPDATE customers SET tr069_device_id=? WHERE username=?");
                    $stmt->bind_param("ss", $d['_id'], $user['username']);
                    $stmt->execute();
                }

                $user['tr069_device_id'] = $d['_id'];
                $device = $d;
                
                // PROJECTION: Fetch Basic Info + Indices 1, 2, 3, 4, 5, 11
                // We fetch up to index 11 because some Huawei/ONT devices map 5G there.
                $details_projection = json_encode([
                    ["InternetGatewayDevice", "DeviceInfo", "SerialNumber"],
                    ["InternetGatewayDevice", "DeviceInfo", "Manufacturer"],
                    ["InternetGatewayDevice", "DeviceInfo", "ProductClass"],
                    ["InternetGatewayDevice", "DeviceInfo", "SoftwareVersion"],
                    
                    // 2.4G (Usually Index 1)
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "1", "SSID"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "1", "KeyPassphrase"],
                    
                    // 5G Candidates (Indices 2, 3, 4, 5, 11)
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "2", "SSID"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "2", "KeyPassphrase"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "3", "SSID"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "3", "KeyPassphrase"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "4", "SSID"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "4", "KeyPassphrase"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "5", "SSID"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "5", "KeyPassphrase"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "11", "SSID"],
                    ["InternetGatewayDevice", "LANDevice", "1", "WLANConfiguration", "11", "KeyPassphrase"]
                ]);

                $details_url = "/devices/" . $d['_id'] . "?projection=" . urlencode($details_projection);
                $genieacsDevice = genieacs_request($details_url, "GET", null);
                
                break;
            }
        }
    }
}

/* ============================
   TR-069 ACTIONS (DYNAMIC SLOTS)
============================ */
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['deviceId'])) {

    $deviceId = $_POST['deviceId'];

    if (isset($_POST['reboot'])) {
        genieacs_request("/devices/$deviceId/tasks", "POST", ["name" => "reboot"]);
        echo "<div class='alert success'>Reboot command sent</div>";
    }

    if (isset($_POST['setwifi'])) {
        $ssid = $_POST['ssid'] ?? '';
        $pass = $_POST['wifi_pass'] ?? '';

        // Start Parameters
        $parameters = [
            ["InternetGatewayDevice.LANDevice.1.WLANConfiguration.1.SSID", $ssid, "xsd:string"],
            ["InternetGatewayDevice.LANDevice.1.WLANConfiguration.1.KeyPassphrase", $pass, "xsd:string"]
        ];

        // Check for Dynamic 5G Slots (2, 3, 4, 5, 11)
        $check_slots = [2, 3, 4, 5, 11];
        foreach ($check_slots as $slot) {
            // Only add to parameters if user filled it in
            $s_val = $_POST['ssid_' . $slot] ?? '';
            $p_val = $_POST['wifi_pass_' . $slot] ?? '';
            
            if (!empty($s_val)) {
                $parameters[] = ["InternetGatewayDevice.LANDevice.1.WLANConfiguration.$slot.SSID", $s_val, "xsd:string"];
            }
            if (!empty($p_val)) {
                $parameters[] = ["InternetGatewayDevice.LANDevice.1.WLANConfiguration.$slot.KeyPassphrase", $p_val, "xsd:string"];
            }
        }

        // Push to Device
        genieacs_request("/devices/$deviceId/tasks", "POST", [
            "name" => "setParameterValues",
            "parameterValues" => $parameters
        ]);

        echo "<div class='alert success'>WiFi settings updated.</div>";
    }
}

include 'includes/header.php';
include 'includes/sidebar.php';
include 'includes/topbar.php';
?>

