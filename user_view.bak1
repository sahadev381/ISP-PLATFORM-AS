<th>Status</th><th>Login</th><th>Duration</th><th>User IP</th><th>NAS</th><th>Download</th><th>Upload</th>
</tr>

<?php
if ($current_session->num_rows > 0):
$s = $current_session->fetch_assoc();
function fbytes($b) {
    if ($b >= 1073741824) return round($b/1073741824,2).' GB';
    if ($b >= 1048576) return round($b/1048576,2).' MB';
    return round($b/1024,2).' KB';
}
?>
<tr>
<td><span class="badge active">Online</span></td>
<td><?= $s['acctstarttime'] ?></td>
<td><?= gmdate("H:i:s", $s['session_seconds']) ?></td>
<td><?= $s['framedipaddress'] ?></td>
<td><?= $s['nasipaddress'] ?></td>
<td><?= fbytes($s['acctoutputoctets']) ?></td>
<td><?= fbytes($s['acctinputoctets']) ?></td>
</tr>

<form method="post">
    <input type="hidden" name="username" value="<?= $user['username'] ?>">
    <button class="btn danger" name="disconnect">Disconnect</button>
</form>

<?php else: ?>
<tr><td colspan="7" style="text-align:center">Offline</td></tr>
<?php endif; ?>
</table>

<hr>

<h2>TR-069 Device Info</h2>
<?php if ($device): ?>
<table>
<tr><th>Serial</th><td><?= $genieacsDevice['InternetGatewayDevice']['DeviceInfo']['SerialNumber']['_value'] ?? 'N/A' ?></td></tr>
<tr><th>Manufacturer</th><td><?= $genieacsDevice['InternetGatewayDevice']['DeviceInfo']['Manufacturer']['_value'] ?? 'N/A' ?></td></tr>
<tr><th>Model</th><td><?= $genieacsDevice['InternetGatewayDevice']['DeviceInfo']['ProductClass']['_value'] ?? 'N/A' ?></td></tr>
<tr><th>Firmware</th><td><?= $genieacsDevice['InternetGatewayDevice']['DeviceInfo']['SoftwareVersion']['_value'] ?? 'N/A' ?></td></tr>
</table>

<h3>TR-069 Actions</h3>
<form method="post">
    <input type="hidden" name="deviceId" value="<?= $user['tr069_device_id'] ?>">
    <button name="reboot" class="btn">Reboot Device</button>
</form>

<form method="post" style="margin-top:10px;">
    <input type="hidden" name="deviceId" value="<?= $user['tr069_device_id'] ?>">
    
    <!-- 2.4GHz WiFi -->
    <fieldset style="padding:10px; margin-bottom:10px; border:1px solid #ccc;">
        <legend><b>2.4GHz WiFi</b></legend>
        SSID: <input type="text" name="ssid" placeholder="SSID 2.4G" 
               value="<?= htmlspecialchars($genieacsDevice['InternetGatewayDevice']['LANDevice']['1']['WLANConfiguration']['1']['SSID']['_value'] ?? '') ?>" required>
        Pass: <input type="text" name="wifi_pass" placeholder="Password 2.4G" 
               value="<?= htmlspecialchars($genieacsDevice['InternetGatewayDevice']['LANDevice']['1']['WLANConfiguration']['1']['KeyPassphrase']['_value'] ?? '') ?>" required>
    </fieldset>

    <!-- 5GHz / Other Bands (Scanning Slots 2, 3, 4, 5, 11) -->
    <?php 
    // Define which slots to check for 5G
    $check_slots = [2, 3, 4, 5, 11];
    
    foreach ($check_slots as $slot) {
        // Check if this slot exists in the device data
        $ssid_val = $genieacsDevice['InternetGatewayDevice']['LANDevice']['1']['WLANConfiguration'][$slot]['SSID']['_value'] ?? '';
        
        // Only show the field if we found data (SSID is not empty)
        if (!empty($ssid_val)) {
    ?>
    <fieldset style="padding:10px; margin-bottom:10px; border:1px solid #ccc;">
        <legend><b>5GHz / Other WiFi (Slot <?= $slot ?>)</b></legend>
        SSID: <input type="text" name="ssid_<?= $slot ?>" placeholder="SSID 5G" 
               value="<?= htmlspecialchars($ssid_val) ?>">
        Pass: <input type="text" name="wifi_pass_<?= $slot ?>" placeholder="Password 5G" 
               value="<?= htmlspecialchars($genieacsDevice['InternetGatewayDevice']['LANDevice']['1']['WLANConfiguration'][$slot]['KeyPassphrase']['_value'] ?? '') ?>">
        <small style="color:gray;">(Leave empty to not update this slot)</small>
    </fieldset>
    <?php 
        } 
    } 
    ?>

    <button name="setwifi" class="btn">Update WiFi Settings</button>
</form>

<?php else: ?>
<p><b>No TR-069 device linked.</b></p>
<?php endif; ?>


